# ─── Skill: Object Memory ─────────────────────────────────────────────────
# Per-skill HMAC secret + skill ID from the Trace dashboard.
# (Legacy names TRACE_HMAC_SECRET / TRACE_SKILL_ID still work as fallback.)
OBJECT_MEMORY_HMAC_SECRET=your_object_memory_hmac_secret_here
OBJECT_MEMORY_SKILL_ID=your_object_memory_skill_id_here

# ─── Skill: Shopping Cart (future) ────────────────────────────────────────
# SHOPPING_CART_HMAC_SECRET=
# SHOPPING_CART_SKILL_ID=

# ─── Shared ──────────────────────────────────────────────────────────────
# Vision LLM (Google AI Studio → https://aistudio.google.com/app/apikey).
# Free tier: Gemini 1.5 Flash, 15 RPM / 1,500 req/day. No credit card required.
GEMINI_API_KEY=your_gemini_api_key_here

# Brain push target (no trailing slash).
BRAIN_BASE_URL=https://brain.endlessriver.ai

# Set to 1 to disable semantic fallback (cheaper, faster, but no fuzzy queries).
DISABLE_SEMANTIC=0

# ─── Daily recap cron (object-memory) ────────────────────────────────────
DAILY_RECAP_CRON=0 21 * * *
DAILY_RECAP_TZ=Asia/Kolkata
DAILY_RECAP_ENABLED=1

# ─── Database paths ──────────────────────────────────────────────────────
# Per-skill DB file. Default: ./data/object-memory.db
# For Railway / Fly / Render disk: /data/object-memory.db
# OBJECT_MEMORY_DB_PATH=/data/object-memory.db
# DATABASE_PATH=./data/object-memory.db  # legacy fallback

# ─── Server ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
