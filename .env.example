# TRACE SKILL SETTINGS
# Copy skillId and hmacSecret from each skill's record in brain (dashboard → Skills)
TRACE_HMAC_SECRET=your_hmac_secret_here
TRACE_SKILL_ID=your_skill_id_here

# Base URL of the brain API (no trailing slash)
BRAIN_BASE_URL=https://brain.endlessriver.ai

# Vision LLM (Google AI Studio → https://aistudio.google.com/app/apikey)
# Free tier: Gemini 1.5 Flash, 15 RPM / 1,500 req/day. No credit card required.
GEMINI_API_KEY=your_gemini_api_key_here

# Set to 1 to disable semantic fallback (cheaper, faster, but no fuzzy queries)
DISABLE_SEMANTIC=0

# DAILY RECAP
# cron expression (any valid node-cron). Default: 9:00 PM daily.
DAILY_RECAP_CRON=0 21 * * *
# IANA timezone for the cron. Default: Asia/Kolkata.
DAILY_RECAP_TZ=Asia/Kolkata
# Set to 0 to disable cron entirely.
DAILY_RECAP_ENABLED=1

# DATABASE
# Absolute or relative path for SQLite file. Default: ./data/memories.db
# For Railway / Fly / Render: point at your mounted volume, e.g. /data/memories.db
DATABASE_PATH=./data/memories.db

# SERVER SETTINGS
PORT=3000
NODE_ENV=development
